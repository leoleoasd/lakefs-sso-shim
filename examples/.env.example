# Copy to .env and fill in.

# Shared HMAC secret — MUST be identical for lakeFS, the ACL server, and the shim.
# Generate one with:  openssl rand -hex 24
SHARED_SECRET=change-me-openssl-rand-hex-24

# OIDC provider (Authentik/Keycloak/Okta/...). Issuer must match the discovery doc exactly
# (Authentik keeps a trailing slash).
OIDC_ISSUER=https://sso.example.com/application/o/lakefs/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Must equal the redirect URI registered on the provider, pointing at the shim:
OIDC_REDIRECT_URL=http://localhost:8088/oidc/callback

# Optional tuning
OIDC_GROUPS_CLAIM=groups
OIDC_USERNAME_CLAIM=preferred_username
LAKEFS_DEFAULT_GROUP=Readers

# Only if you switch lakeFS blockstore to S3 in docker-compose.yml
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
